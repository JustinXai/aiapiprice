---
import { siteConfig } from '../data/site';

const { fourQuestions } = siteConfig;
---

<section class="questions-section">
  <div class="container">
    <h2 class="section-title">你可能关心的问题</h2>
    <div class="questions-grid">
      {fourQuestions.map(q => (
        <div class="question-card">
          <h3><a href={q.href}>{q.q}</a></h3>
          <p>{q.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
