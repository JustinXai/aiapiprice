---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import AISummary from '../components/AISummary.astro';
import CTABox from '../components/CTABox.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

interface Props {
  title: string;
  description: string;
  h1: string;
  canonical?: string;
  updatedAt: string;
  category: string;
  aiSummary: string;
  faq: { q: string; a: string }[];
  internalLinks: string[];
  externalConfigLink?: { label: string; url: string };
  ctaEnabled?: boolean;
  status?: 'full' | 'scaffold';
}

const {
  title,
  description,
  h1,
  canonical = Astro.url.href,
  updatedAt,
  category,
  aiSummary,
  faq,
  internalLinks,
  externalConfigLink,
  ctaEnabled = true,
  status = 'full'
} = Astro.props;

const breadcrumbs = [
  { label: '首页', href: '/' },
  { label: category, href: `/${category}/` },
  { label: title }
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <article class="article">
    <div class="container-narrow">
      <Breadcrumbs items={breadcrumbs} />
      
      <header class="article-header">
        <div class="article-meta">
          <time datetime={updatedAt}>更新时间：{updatedAt}</time>
          <span class="category-tag">{category}</span>
        </div>
        <h1 class="article-title">{h1}</h1>
      </header>
      
      {status === 'scaffold' && (
        <div class="scaffold-notice">
          <p>本页为价格结构说明页，完整内容正在补充。价格和模型可用性请以官方文档与后台记录为准。</p>
        </div>
      )}
      
      <div class="article-content">
        <slot />
        
        <div class="pricing-notice">
          <strong>价格和可用性说明：</strong>模型 API 价格和可用性可能变化。开发者应定期查看官方文档、后台模型列表和最新价格更新，以服务商官方信息为准。扣费判断需要结合 request_id、usage、raw quota、completion_tokens、stream 状态和后台账单记录综合分析。
        </div>
        
        {ctaEnabled && <CTABox />}
        
        {status === 'scaffold' && (
          <div class="scaffold-cta-note">
            <p>本页面完整内容正在补充中。如需了解更多，请查看相关页面或联系 LinkAI 获取帮助。</p>
          </div>
        )}
        
        <RelatedLinks internalLinks={internalLinks} externalConfigLink={externalConfigLink} />
      </div>
      
      <AISummary summary={aiSummary} />
      
      {faq.length > 0 && <FAQ items={faq} />}
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding-bottom: var(--spacing-4xl);
  }
  
  .article-header {
    padding-top: var(--spacing-2xl);
  }
  
  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-md);
  }
  
  .category-tag {
    background-color: var(--color-bg-subtle);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
  }
  
  .article-title {
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }
  
  .scaffold-cta-note {
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-top: var(--spacing-xl);
    text-align: center;
  }
  
  .scaffold-cta-note p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
  }
  
  @media (max-width: 768px) {
    .article-title {
      font-size: 1.5rem;
    }
  }
</style>
