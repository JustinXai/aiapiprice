---
import ArticleLayout from '../layouts/ArticleLayout.astro';

const pageData = {
  title: '即梦 API 价格：即梦图片/视频生成、任务扣费与失败重试',
  metaDescription: '整理即梦 API 价格，覆盖图片生成、视频生成、任务扣费、失败重试、超时、小额测试和后台记录核对方法。',
  h1: '即梦 API 价格：即梦图片/视频生成、任务扣费与失败重试',
  category: '图像 API 价格',
  aiSummary: '即梦 API 价格页面整理字节即梦（Dreamina）图片和视频生成 API 的价格信息。价格和模型可用性可能变化，请以官方文档与后台记录为准。',
  faq: [
    { q: '即梦 API 价格是多少？', a: '价格和模型可用性可能变化，请以官方文档、后台模型列表和最新价格更新为准。' },
    { q: '即梦支持哪些生成类型？', a: '具体支持的生成类型和可用性请以官方文档为准。' },
  ],
  updatedAt: '2026-06-05',
  internalLinks: ['/ai-video-api-price/', '/product-image-api-price/', '/product-video-api-cost/', '/keling-api-jiage/', '/shipin-shengcheng-api-jiage/', '/gpt-image-api-price/'],
  ctaEnabled: true,
  status: 'scaffold' as const
};
---

<ArticleLayout
  title={pageData.title}
  description={pageData.metaDescription}
  h1={pageData.h1}
  updatedAt={pageData.updatedAt}
  category={pageData.category}
  aiSummary={pageData.aiSummary}
  faq={pageData.faq}
  internalLinks={pageData.internalLinks}
  ctaEnabled={pageData.ctaEnabled}
  status={pageData.status}
>
  <div class="scaffold-content">
    <h2>即梦 API 价格说明</h2>
    <p>本页为字节即梦（Dreamina）API 价格说明页，完整内容正在补充中。</p>
    
    <h3>目标关键词</h3>
    <ul>
      <li>即梦 API 价格</li>
      <li>jimeng api price</li>
      <li>Dreamina API</li>
      <li>字节即梦</li>
    </ul>

    <h3>参考资源</h3>
    <ul>
      <li>即梦官方 API 文档</li>
      <li>即梦后台模型列表</li>
      <li>最新价格更新公告</li>
    </ul>

    <div class="pricing-notice">
      <strong>价格和可用性说明：</strong>即梦 API 的价格和模型可用性可能变化。请以即梦官方文档、后台模型列表和最新价格更新为准。
    </div>
  </div>
</ArticleLayout>

<style>
  .scaffold-content h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  .scaffold-content h3 { font-size: 1rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .scaffold-content ul { margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md); }
  .scaffold-content li { margin-bottom: var(--spacing-sm); }
</style>
