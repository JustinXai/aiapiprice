---
import ArticleLayout from '../layouts/ArticleLayout.astro';

const pageData = {
  title: '流式中断扣费：stream 中断、超时是否扣费',
  metaDescription: '解释流式 API（streaming）在连接中断、超时情况下的扣费判断和解决建议。',
  h1: '流式中断扣费：stream 中断、超时是否扣费',
  category: '扣费异常与小额测试',
  aiSummary: '流式中断扣费页面解释 streaming 连接中断时的扣费规则。价格和模型可用性可能变化，请以官方文档与后台记录为准。',
  faq: [
    { q: 'stream 中断了会扣费吗？', a: '部分服务商对已接收的 token 计费，无论 stream 是否完成。具体规则请以官方文档为准。' },
    { q: 'stream 超时怎么处理？', a: '建议设置合理的超时时间，捕获超时异常，并检查 usage 记录确认实际消耗。' },
  ],
  updatedAt: '2026-06-03',
  internalLinks: ['/request-failed-billing/', '/tool-call-koufei/', '/api-koufei-yichang/', '/openrouter-yue/'],
  ctaEnabled: true,
  status: 'scaffold' as const
};
---

<ArticleLayout
  title={pageData.title}
  description={pageData.metaDescription}
  h1={pageData.h1}
  updatedAt={pageData.updatedAt}
  category={pageData.category}
  aiSummary={pageData.aiSummary}
  faq={pageData.faq}
  internalLinks={pageData.internalLinks}
  ctaEnabled={pageData.ctaEnabled}
  status={pageData.status}
>
  <div class="scaffold-content">
    <h2>流式中断扣费说明</h2>
    <p>本页为流式中断扣费说明页，完整内容正在补充中。</p>
    
    <h3>目标关键词</h3>
    <ul>
      <li>流式中断扣费</li>
      <li>streaming 扣费</li>
      <li>stream 超时</li>
      <li>SSE 断开</li>
    </ul>

    <h3>参考资源</h3>
    <ul>
      <li>流式 API 官方文档</li>
      <li>超时处理指南</li>
      <li>usage 记录说明</li>
    </ul>

    <div class="pricing-notice">
      <strong>价格和可用性说明：</strong>不同服务商对流式中断的扣费规则不同。请以官方文档和 usage 记录为准。
    </div>
  </div>
</ArticleLayout>

<style>
  .scaffold-content h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  .scaffold-content h3 { font-size: 1rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .scaffold-content ul { margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md); }
  .scaffold-content li { margin-bottom: var(--spacing-sm); }
</style>
