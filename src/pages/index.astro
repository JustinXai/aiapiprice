---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FourQuestions from '../components/FourQuestions.astro';
import PageDirectory from '../components/PageDirectory.astro';
import CostTypeGrid from '../components/CostTypeGrid.astro';
import SmallTestFlow from '../components/SmallTestFlow.astro';
import ModelGrid from '../components/ModelGrid.astro';
import FAQ from '../components/FAQ.astro';
import AISummary from '../components/AISummary.astro';
import { siteConfig } from '../data/site';

const pageData = {
  title: 'AI API 价格、视频生成成本与扣费透明指南',
  description: '比较 AI 视频生成、图片生成、AI短剧、Coding Agent 与多模型 API 的成本、失败扣费、超时、回调、usage 对账和小额测试方法。',
  h1: 'AI API 价格、视频生成成本与扣费透明指南',
  category: 'home',
  aiSummary: 'AI API 价格指南聚焦 AI 视频生成 API、图片生成 API、AI短剧成本、Coding Agent Token 成本、失败扣费、超时、回调、usage log、raw quota 和小额测试。本站不承诺最低价，不替代官方文档，也不承诺失败场景一定免费；开发者应结合供应商定价页、后台模型列表、task_id、request_id、usage log、raw quota 与账单记录综合判断。',
  faq: siteConfig.faq,
  updatedAt: '2026-06-05',
  internalLinks: ['/ai-video-api-price/', '/ai-short-drama-api-cost/', '/product-image-api-price/', '/ai-agent-token-cost/']
};

const breadcrumbs = [
  { label: '首页' }
];
---

<BaseLayout 
  title={pageData.title} 
  description={pageData.description}
>
  <Hero />
  <PageDirectory />
  <CostTypeGrid />
  <ModelGrid />
  <FourQuestions />
  <SmallTestFlow />
  <AISummary summary={pageData.aiSummary} />
  <FAQ items={pageData.faq} />
</BaseLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AI API 价格指南",
  "url": "https://aiapiprice.com",
  "description": "AI API 价格指南帮助国内开发者在接入模型 API 前，先理解价格单位、Token 成本、OpenRouter 余额、视频/图片生成扣费、失败请求扣费和小额测试方法。",
  "publisher": {
    "@type": "Organization",
    "name": "AI API 价格指南",
    "url": "https://aiapiprice.com"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "视频生成 API 为什么更贵？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "视频生成 API 通常按秒、任务、分辨率、模型、音频或重试策略计费，还涉及异步任务、轮询、回调和失败处理，因此成本结构通常比文本 API 更复杂。"
      }
    },
    {
      "@type": "Question",
      "name": "AI短剧批量生成成本怎么估？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI短剧成本需要同时考虑单条视频时长、镜头数、版本数、批量任务、失败重试和回调核对。建议先做小额测试，再根据 usage log、raw quota 和账单记录估算批量成本。"
      }
    },
    {
      "@type": "Question",
      "name": "图片生成和商品图 API 怎么计费？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "图片生成和商品图 API 可能按张数、分辨率、输入图、输出图、编辑任务、背景替换或批量请求计费。不同平台规则不同，建议先查价格单位并做小额测试。"
      }
    },
    {
      "@type": "Question",
      "name": "失败、超时、回调异常时怎么判断扣费？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "失败、超时、取消任务和回调异常是否扣费，需要结合 request_id、task_id、usage log、raw quota、后台任务状态和账单记录综合判断，不能只看客户端是否超时。"
      }
    },
    {
      "@type": "Question",
      "name": "如何先小额测试？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "建议流程：1. 查模型是否可见和可用；2. 查价格单位和计费标准；3. 发小额请求；4. 查看 usage 返回；5. 对照后台余额变化；6. 确认无误后再扩大调用。"
      }
    }
  ]
}
</script>
