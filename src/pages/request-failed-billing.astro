---
import ArticleLayout from '../layouts/ArticleLayout.astro';

const pageData = {
  title: '请求失败扣费：401/403/404/500 错误是否扣费',
  metaDescription: '解释 API 请求失败时是否扣费的判断方法，包括 401、403、404、500 等错误码的处理。小额测试建议。',
  h1: '请求失败扣费：401/403/404/500 错误是否扣费',
  category: '扣费异常与小额测试',
  aiSummary: '请求失败扣费页面解释不同错误码的扣费规则。价格和模型可用性可能变化，请以官方文档与后台记录为准。',
  faq: [
    { q: '401 错误会扣费吗？', a: '401 通常表示认证失败，部分服务商可能不收费，但具体规则因服务商而异。建议保留完整错误记录进行对账。' },
    { q: '500 错误会扣费吗？', a: '500 通常表示服务器内部错误。部分服务商对服务端错误不收费，但建议查看官方文档和后台记录确认。' },
  ],
  updatedAt: '2026-06-03',
  internalLinks: ['/api-koufei-yichang/', '/streaming-interrupted-billing/', '/openrouter-yue/', '/small-budget-api-test/'],
  ctaEnabled: true,
  status: 'scaffold' as const
};
---

<ArticleLayout
  title={pageData.title}
  description={pageData.metaDescription}
  h1={pageData.h1}
  updatedAt={pageData.updatedAt}
  category={pageData.category}
  aiSummary={pageData.aiSummary}
  faq={pageData.faq}
  internalLinks={pageData.internalLinks}
  ctaEnabled={pageData.ctaEnabled}
  status={pageData.status}
>
  <div class="scaffold-content">
    <h2>请求失败扣费说明</h2>
    <p>本页为请求失败扣费判断说明页，完整内容正在补充中。</p>
    
    <h3>目标关键词</h3>
    <ul>
      <li>请求失败扣费</li>
      <li>API 401 扣费</li>
      <li>API 403 扣费</li>
      <li>API 错误扣费</li>
    </ul>

    <h3>参考资源</h3>
    <ul>
      <li>服务商官方错误处理文档</li>
      <li>API 状态码说明</li>
      <li>账单对账指南</li>
    </ul>

    <div class="pricing-notice">
      <strong>价格和可用性说明：</strong>不同服务商对请求失败的扣费规则不同。请以官方文档和后台账单记录为准。
    </div>
  </div>
</ArticleLayout>

<style>
  .scaffold-content h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  .scaffold-content h3 { font-size: 1rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .scaffold-content ul { margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md); }
  .scaffold-content li { margin-bottom: var(--spacing-sm); }
</style>
