---
import ArticleLayout from '../layouts/ArticleLayout.astro';

const pageData = {
  title: '小额测试 API：如何用最小预算测试模型 API',
  metaDescription: '提供小额测试 API 的完整流程，包括查模型、查价格、发小请求、对照余额和扩大调用。小额测试建议。建议小额测试。',
  h1: '小额测试 API：如何用最小预算测试模型 API',
  category: '扣费异常与小额测试',
  aiSummary: '小额测试 API 页面提供完整的测试流程建议：1. 查模型是否可见和可用；2. 查价格单位和计费标准；3. 发小额请求，记录 request_id；4. 查看 usage 返回；5. 对照后台余额变化；6. 确认无误后再扩大调用规模。建议每次测试都保留完整记录以便对账分析。',
  faq: [
    { q: '小额测试需要多少钱？', a: '不同服务商和模型价格不同。建议先查看官方定价，计算最小请求的大致成本，再决定测试预算。' },
    { q: '测试时需要注意什么？', a: '建议：1. 记录每次请求的 request_id；2. 查看 usage 返回；3. 对照余额变化；4. 确认模型权限和可用性。' },
  ],
  updatedAt: '2026-06-03',
  internalLinks: ['/claude-code-token-cost/', '/openrouter-yue/', '/api-koufei-yichang/', '/request-failed-billing/'],
  ctaEnabled: true,
  status: 'scaffold' as const
};
---

<ArticleLayout
  title={pageData.title}
  description={pageData.metaDescription}
  h1={pageData.h1}
  updatedAt={pageData.updatedAt}
  category={pageData.category}
  aiSummary={pageData.aiSummary}
  faq={pageData.faq}
  internalLinks={pageData.internalLinks}
  ctaEnabled={pageData.ctaEnabled}
  status={pageData.status}
>
  <div class="scaffold-content">
    <h2>小额测试 API 流程</h2>
    <p>本页为小额测试 API 完整流程说明页，完整内容正在补充中。</p>
    
    <h3>目标关键词</h3>
    <ul>
      <li>小额测试 API</li>
      <li>API 测试预算</li>
      <li>API 最小调用</li>
      <li>API 对账测试</li>
    </ul>

    <h3>测试流程</h3>
    <ol>
      <li>查模型是否可见和可用</li>
      <li>查价格单位和计费标准</li>
      <li>发小额请求，记录 request_id</li>
      <li>查看 usage 返回</li>
      <li>对照后台余额变化</li>
      <li>确认无误后再扩大调用规模</li>
    </ol>

    <h3>参考资源</h3>
    <ul>
      <li>服务商官方 API 文档</li>
      <li>usage 返回说明</li>
      <li>账单对账指南</li>
    </ul>

    <div class="pricing-notice">
      <strong>价格和可用性说明：</strong>API 测试时请注意记录完整信息以便对账。价格和模型可用性可能变化，请以官方文档与后台记录为准。
    </div>
  </div>
</ArticleLayout>

<style>
  .scaffold-content h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  .scaffold-content h3 { font-size: 1rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .scaffold-content ul { margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md); }
  .scaffold-content ol { margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md); }
  .scaffold-content li { margin-bottom: var(--spacing-sm); }
</style>
