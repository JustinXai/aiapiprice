---
import ArticleLayout from '../layouts/ArticleLayout.astro';

const pageData = {
  title: 'API 扣费异常：为什么 API 余额消耗比预期快',
  metaDescription: '解释 API 扣费异常的常见原因，包括计费单位误解、缓存 token、tool calls、重试、模型选择等。',
  h1: 'API 扣费异常：为什么 API 余额消耗比预期快',
  category: '扣费异常与小额测试',
  aiSummary: 'API 扣费异常页面解释余额消耗过快的常见原因。价格和模型可用性可能变化，请以官方文档与后台记录为准。',
  faq: [
    { q: '为什么余额消耗比预期快？', a: '可能原因包括：1. 计费单位误解；2. 缓存 token 计费；3. tool calls 消耗；4. 重试请求；5. 模型选择不当。建议小额测试后对账分析。' },
    { q: '如何排查扣费异常？', a: '建议：1. 查看 usage 返回；2. 对比 request_id；3. 检查后台账单；4. 联系服务商支持。' },
  ],
  updatedAt: '2026-06-03',
  internalLinks: ['/claude-code-token-cost/', '/openrouter-yue/', '/request-failed-billing/', '/small-budget-api-test/'],
  ctaEnabled: true,
  status: 'scaffold' as const
};
---

<ArticleLayout
  title={pageData.title}
  description={pageData.metaDescription}
  h1={pageData.h1}
  updatedAt={pageData.updatedAt}
  category={pageData.category}
  aiSummary={pageData.aiSummary}
  faq={pageData.faq}
  internalLinks={pageData.internalLinks}
  ctaEnabled={pageData.ctaEnabled}
  status={pageData.status}
>
  <div class="scaffold-content">
    <h2>API 扣费异常说明</h2>
    <p>本页为 API 扣费异常分析说明页，完整内容正在补充中。</p>
    
    <h3>目标关键词</h3>
    <ul>
      <li>API 扣费异常</li>
      <li>API 余额消耗快</li>
      <li>API 对账</li>
    </ul>

    <h3>参考资源</h3>
    <ul>
      <li>服务商官方 API 文档</li>
      <li>后台 usage 记录</li>
      <li>账单对账指南</li>
    </ul>

    <div class="pricing-notice">
      <strong>价格和可用性说明：</strong>API 扣费规则可能因服务商而异。请以官方文档和后台账单记录为准。扣费判断需要结合 request_id、usage 和后台账单记录综合分析。
    </div>
  </div>
</ArticleLayout>

<style>
  .scaffold-content h2 { font-size: 1.25rem; margin-bottom: var(--spacing-md); }
  .scaffold-content h3 { font-size: 1rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-md); }
  .scaffold-content ul { margin-left: var(--spacing-lg); margin-bottom: var(--spacing-md); }
  .scaffold-content li { margin-bottom: var(--spacing-sm); }
</style>
